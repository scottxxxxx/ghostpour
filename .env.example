# =============================================================================
# GhostPour Configuration
# Copy to .env and fill in your values
# All variables are prefixed with CZ_
# =============================================================================

# Required — JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
CZ_JWT_SECRET=change-me-to-a-random-64-char-string

# Required — Your iOS app's bundle ID (for Apple Sign In verification)
CZ_APPLE_BUNDLE_ID=com.example.myapp

# Provider API Keys (set the ones you use)
CZ_OPENAI_API_KEY=
CZ_ANTHROPIC_API_KEY=
CZ_GOOGLE_API_KEY=
CZ_GEMINI_API_KEY=
CZ_XAI_API_KEY=
CZ_DEEPSEEK_API_KEY=
CZ_KIMI_API_KEY=
CZ_QWEN_API_KEY=

# Admin key for manual tier management (POST /webhooks/admin/set-tier)
CZ_ADMIN_KEY=change-me

# Optional — Email delivery (Resend). When unset, app.secrets.get_secret
# falls back to GCP Secret Manager. Set CZ_GCP_PROJECT below (or rely
# on Application Default Credentials project resolution) for SM lookup.
# CZ_RESEND_API_KEY=

# Optional — GCP project hosting Secret Manager secrets. When unset,
# falls back to ADC project resolution (gcloud config / GCE metadata).
# CZ_GCP_PROJECT=

# Optional — Database path (default: sqlite in ./data/)
# CZ_DATABASE_URL=sqlite+aiosqlite:///./data/ghostpour.db

# Optional — Pricing data source (default: LiteLLM's GitHub JSON)
# Swap to any URL that serves compatible JSON (e.g., OpenRouter, your own file)
# CZ_PRICING_SOURCE_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
# CZ_PRICING_REFRESH_SECONDS=86400

# Optional — JWT token lifetimes
# CZ_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# CZ_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Optional — Config file paths
# CZ_TIER_CONFIG_PATH=config/tiers.yml
# CZ_PROVIDER_CONFIG_PATH=config/providers.yml

# Optional — Context Quilt integration
# Set CZ_CQ_BASE_URL to enable. When enabled, requests with context_quilt=true
# will recall context from CQ before querying the LLM, and capture query+response after.
# CZ_CQ_BASE_URL=https://cq.example.com
# CZ_CQ_APP_ID=cloudzap
# CZ_CQ_CLIENT_SECRET=           # Client secret for CQ JWT auth (empty = X-App-ID fallback)
# CZ_CQ_RECALL_TIMEOUT_MS=200
