{
  "version": 12,
  "limits": {
    "project_chat": {
      "max_input_chars": {
        "free": 200000,
        "plus": 600000,
        "pro": 720000
      }
    }
  },
  "flags": {},
  "intervals": {},
  "documents": {
    "enabled": true,
    "min_tier": "pro",
    "accepted_types": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.presentationml.presentation",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    ],
    "per_file_max_mb": 25,
    "max_files": 2,
    "allowed_users": [],
    "passthrough": {
      "max_pdf_pages": 600,
      "max_total_mb": 22
    },
    "generation": {
      "enabled": true,
      "min_tier": "pro",
      "formats": [
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "max_files_out": 2,
      "max_file_out_mb": 25,
      "confirmation": {
        "enabled": true,
        "expected_seconds": 150,
        "poll_after_seconds": 5,
        "offer_text": "Parece una solicitud de archivo. Puedo crear {format} para descargar y compartir, tarda unos dos minutos, o responder aquí mismo en el chat. ¿Quieres el archivo?",
        "format_nouns": {
          "xlsx": "una hoja de cálculo de Excel (.xlsx)",
          "docx": "un documento de Word (.docx)",
          "pptx": "una presentación de PowerPoint (.pptx)",
          "pdf": "un archivo PDF"
        },
        "offer_text_gist": "Parece que quieres {format} {gist}. Crear el archivo real tarda unos dos minutos, o puedo mostrarlo aquí mismo en el chat. ¿Quieres el archivo?",
        "teaser_text": "¿Quieres esto como un archivo descargable?"
      }
    }
  }
}
