{
  "version": 11,
  "limits": {
    "project_chat": {
      "max_input_chars": {
        "free": 100000,
        "plus": 300000,
        "pro": 360000
      }
    }
  },
  "flags": {},
  "intervals": {},
  "documents": {
    "enabled": true,
    "min_tier": "pro",
    "accepted_types": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.presentationml.presentation",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    ],
    "per_file_max_mb": 25,
    "max_files": 2,
    "allowed_users": [],
    "passthrough": {
      "max_pdf_pages": 600,
      "max_total_mb": 22
    },
    "generation": {
      "enabled": true,
      "min_tier": "pro",
      "formats": [
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "max_files_out": 2,
      "max_file_out_mb": 25,
      "confirmation": {
        "enabled": true,
        "expected_seconds": 150,
        "poll_after_seconds": 5,
        "offer_text": "ファイル作成のリクエストのようです。ダウンロードして共有できる{format}を作成できます（約2分）。このチャットで直接お答えすることもできます。ファイルを作成しますか？",
        "format_nouns": {
          "xlsx": "Excelスプレッドシート（.xlsx）",
          "docx": "Word文書（.docx）",
          "pptx": "PowerPointプレゼン（.pptx）",
          "pdf": "PDFファイル"
        },
        "offer_text_gist": "{gist}の{format}をご希望のようですね。実ファイルの作成には約2分かかります。このチャットに直接表示することもできます。ファイルを作成しますか？",
        "teaser_text": "これをダウンロードできるファイルにしますか？"
      }
    }
  }
}
