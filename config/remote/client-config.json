{
  "version": 3,
  "limits": {
    "project_chat": {
      "max_input_chars": {
        "free": 200000,
        "plus": 600000,
        "pro": 720000
      }
    }
  },
  "flags": {},
  "intervals": {},
  "documents": {
    "enabled": true,
    "min_tier": "pro",
    "accepted_types": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.presentationml.presentation"
    ],
    "per_file_max_mb": 25,
    "max_files": 2,
    "allowed_users": [],
    "passthrough": {
      "max_pdf_pages": 600,
      "max_total_mb": 22
    },
    "generation": {
      "enabled": false,
      "min_tier": "pro",
      "formats": [
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "max_files_out": 2,
      "max_file_out_mb": 25,
      "confirmation": {
        "enabled": false,
        "expected_seconds": 150,
        "poll_after_seconds": 5,
        "offer_text": "This looks like a file request. Generate {format} from this project? Takes about two minutes.",
        "format_nouns": {
          "xlsx": "a spreadsheet",
          "docx": "a Word document",
          "pptx": "a slide deck",
          "pdf": "a PDF"
        }
      }
    }
  }
}
